{
  "multipart": [
    { "apply": { "model": "industrial_core:block/ferro_cable_center" } },
    { "when": { "north": "true" }, "apply": { "model": "industrial_core:block/ferro_cable_side" } },
    { "when": { "east": "true" },  "apply": { "model": "industrial_core:block/ferro_cable_side", "y": 90 } },
    { "when": { "south": "true" }, "apply": { "model": "industrial_core:block/ferro_cable_side", "y": 180 } },
    { "when": { "west": "true" },  "apply": { "model": "industrial_core:block/ferro_cable_side", "y": 270 } },
    { "when": { "up": "true" },    "apply": { "model": "industrial_core:block/ferro_cable_side", "x": 270 } },
    { "when": { "down": "true" },  "apply": { "model": "industrial_core:block/ferro_cable_side", "x": 90 } }
  ]
}